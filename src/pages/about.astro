---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Studio">
  <p class="text-sm text-gray-400 uppercase tracking-widest mb-4">About</p>
  <h1 class="text-4xl font-semibold mb-6 max-w-xl">We believe good design is invisible.</h1>
  <p class="text-gray-500 text-lg max-w-prose mb-12">
    Studio is a small, focused design and development team. We work with founders, brands, and teams to turn complex ideas into clear, beautiful products.
  </p>

  <div class="border-t border-gray-100 pt-12 grid grid-cols-1 sm:grid-cols-2 gap-12">
    <div>
      <h2 class="text-xl font-medium mb-3">Our approach</h2>
      <p class="text-gray-500 leading-relaxed">
        We start with questions, not solutions. Understanding the problem deeply leads to work that actually fits — and lasts. We keep teams small and communication direct.
      </p>
    </div>
    <div>
      <h2 class="text-xl font-medium mb-3">Our values</h2>
      <ul class="text-gray-500 space-y-2">
        <li>Clarity over complexity</li>
        <li>Function before decoration</li>
        <li>Long-term thinking</li>
        <li>Honest collaboration</li>
      </ul>
    </div>
  </div>
</Layout>
