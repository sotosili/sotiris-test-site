---
import Layout from '../layouts/Layout.astro';

const projects = [
  { title: 'Arc Finance', category: 'Brand + Web', year: '2024' },
  { title: 'Loom Studio', category: 'Identity', year: '2024' },
  { title: 'Onyx App', category: 'Product Design', year: '2023' },
  { title: 'Meridian', category: 'Web + Dev', year: '2023' },
  { title: 'Habitat Co.', category: 'Brand', year: '2022' },
  { title: 'Pulse Health', category: 'Web + Dev', year: '2022' },
];
---

<Layout title="Portfolio — Studio">
  <p class="text-sm text-gray-400 uppercase tracking-widest mb-4">Portfolio</p>
  <h1 class="text-4xl font-semibold mb-6 max-w-xl">Selected work.</h1>
  <p class="text-gray-500 text-lg max-w-md mb-12">A few projects we're proud of.</p>

  <div class="border-t border-gray-100">
    {projects.map(({ title, category, year }) => (
      <div class="flex items-center justify-between py-5 border-b border-gray-100 group cursor-pointer">
        <div>
          <p class="font-medium group-hover:text-gray-500 transition-colors">{title}</p>
          <p class="text-sm text-gray-400">{category}</p>
        </div>
        <span class="text-sm text-gray-300">{year}</span>
      </div>
    ))}
  </div>
</Layout>
