---
export interface Props {
  eyebrow?: string;
  headline?: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  eyebrow = 'Sotiris Iliadis',
  headline = 'AI Ethical\nDesigner',
  subtitle = 'EU AI Act compliance · WCAG 2.1 AA · 13 years experience',
  primaryCta = { label: 'See my work', href: '/portfolio' },
  secondaryCta = { label: 'Get in touch', href: '/contact' },
} = Astro.props;
---

<section class="flex items-center min-h-[640px] px-[120px] bg-white">
  <div class="flex flex-col gap-8">
    <p class="text-[13px] font-medium tracking-[3px] text-[#666666] uppercase">
      {eyebrow}
    </p>

    <h1 class="text-[96px] font-bold leading-[0.95] text-[#1A1A1A] max-w-[720px] whitespace-pre-line">
      {headline}
    </h1>

    <p class="text-[18px] font-normal text-[#666666]">
      {subtitle}
    </p>

    <div class="flex items-center gap-4">
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center h-[52px] px-8 rounded bg-[#1A1A1A] text-white text-[15px] font-medium hover:bg-[#333333] transition-colors"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex items-center justify-center h-[52px] px-8 rounded bg-[#F5F5F5] text-[#1A1A1A] text-[15px] font-medium hover:bg-[#E8E8E8] transition-colors"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
